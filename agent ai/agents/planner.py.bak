from openai import OpenAI
from app.config import OPENAI_API_KEY
from memory.memory import get_memory_by_user, get_last_result_by_user, save_conversation_memory
from tools.db_tool import get_dosen_by_user_id
from agents.parser import parse_grouping_request, extract_detailed_requirements, detect_question_vs_command, detect_dosen_query, parse_dosen_query, detect_pembimbing_command, parse_pembimbing_command
from agents.step_builder import build_grouping_steps
from agents.capability_handler import detect_capability_query, generate_capability_response, get_capability_summary
import json

client = OpenAI(api_key=OPENAI_API_KEY)


def clean_json(text: str):
    """
    Bersihkan output AI dari markdown ```json
    """
    if "```" in text:
        text = text.replace("```json", "").replace("```", "")
    return text.strip()


def detect_modify_keywords(prompt):
    """Detect jika user ingin modify existing groups"""
    modify_keywords = ["acak", "ubah", "jangan", "harus", "kembali", "ulangi", "ganti", "tukar"]
    prompt_lower = prompt.lower()
    return any(keyword in prompt_lower for keyword in modify_keywords)


def extract_num_groups(prompt):
    """Extract jumlah kelompok dari prompt user.
    
    Contoh:
    - "buat 5 kelompok" → 5
    - "bagi 3 kelompok" → 3
    - "buat kelompok 7" → 7
    - Tidak ada → None
    """
    import re
    
    prompt_lower = prompt.lower()
    
    # Pattern 1: "N kelompok"
    match = re.search(r'(\d+)\s+(?:kelompok|grup|group)', prompt_lower)
    if match:
        return int(match.group(1))
    
    # Pattern 2: "kelompok N"
    match = re.search(r'(?:kelompok|grup|group)\s+(\d+)', prompt_lower)
    if match:
        return int(match.group(1))
    
    return None


def detect_create_group_keywords(prompt):
    """Detect jika user ingin membuat/membagi kelompok baru"""
    create_keywords = ["buat kelompok", "bagi kelompok", "buat grup", "bagi grup", "create group", "divide group", "kelompok", "pembagian kelompok"]
    prompt_lower = prompt.lower()
    return any(keyword in prompt_lower for keyword in create_keywords)


def detect_career_based_grouping(prompt):
    """Detect jika user ingin grouping berdasarkan karir/kategori"""
    career_keywords = [
        "karir", "kategori", "balance", "seimbang", "backend", "frontend", "ui", "ux", "data", "ai",
        "keseimbangan", "keahlian", "skill", "expertise", "specialization", "spesialisasi"
    ]
    prompt_lower = prompt.lower()
    return any(keyword in prompt_lower for keyword in career_keywords)


def detect_view_existing_groups(prompt):
    """Detect jika user ingin lihat kelompok yang sudah ada"""
    view_keywords = [
        "lihat kelompok", "lihat group", "lihat grup", "kelompok saya",
        "kelompok apa", "kelompok siapa", "anggota kelompok", "siapa saja di kelompok",
        "show group", "show kelompok", "display group", "current group", "sekarang",
        "tampilkan kelompok"
    ]
    prompt_lower = prompt.lower()
    return any(keyword in prompt_lower for keyword in view_keywords)


def extract_group_number(prompt):
    """Extract group number dari prompt seperti 'tampilkan anggota kelompok 1'"""
    import re
    
    # Pattern: "kelompok X" atau "group X" 
    patterns = [
        r'kelompok\s+(\d+)',
        r'group\s+(\d+)',
        r'grup\s+(\d+)',
        r'anggota\s+(?:kelompok|group|grup)\s+(\d+)',
        r'tampilkan\s+(?:anggota\s+)?(?:kelompok|group|grup)\s+(\d+)',
    ]
    
    prompt_lower = prompt.lower()
    
    for pattern in patterns:
        match = re.search(pattern, prompt_lower)
        if match:
            return int(match.group(1))
    
    return None


def detect_greeting_keywords(prompt):
    """Detect jika user hanya menyapa/greeting"""
    greeting_keywords = [
        "halo", "hello", "hi", "hai", "pagi", "siang", "sore", "malam",
        "assalamualaikum", "assalamu", "apa kabar", "kabar apa",
        "gimana", "bagaimana", "siapa aku", "siapa saya", "siapa nama saya",
        "nama saya", "nama aku", "identitas", "biodata"
    ]
    prompt_lower = prompt.lower().strip()
    
    # Check if prompt matches greeting keywords
    for keyword in greeting_keywords:
        # Exact match or as whole word (not part of another word)
        if keyword in prompt_lower:
            # Allow some short follow-up words with greeting
            words = prompt_lower.split()
            # If prompt is just greeting keywords (1-3 words), it's a greeting
            if len(words) <= 3:
                return True
            # If more than 3 words, check if it's still just greeting + punctuation
            # e.g. "halo, apa kabar?" (4 words including punctuation)
            if len(words) <= 4 and any(keyword in " ".join(words) for keyword in greeting_keywords):
                continue
    
    return False


def plan(prompt, dosen_context, user_id=None, existing_groups=None):

    # Check if user is asking about capabilities/instructions
    if detect_capability_query(prompt):
        print(f"[PLANNER] Detected CAPABILITY query: {prompt}")
        
        capability_response = generate_capability_response(prompt)
        
        capability_plan = {
            "type": "capability_query",
            "response": capability_response["response"],
            "capabilities": capability_response["capabilities_shown"]
        }
        
        # Save to memory
        if user_id:
            save_conversation_memory(
                user_id=user_id,
                prompt=prompt,
                response=capability_response["response"],
                query_type="capability_query",
                status="success"
            )
        
        return json.dumps(capability_plan)

    # Check if user is asking about dosen (lecturer)
    if detect_dosen_query(prompt):
        print(f"[PLANNER] Detected DOSEN query: {prompt}")
        
        # Get context
        context = dosen_context[0] if (isinstance(dosen_context, (list, tuple)) and len(dosen_context) > 0) else None
        
        # Parse dosen query
        parsed_dosen = parse_dosen_query(prompt, context)
        
        # Build dosen response plan
        dosen_plan = {
            "type": "dosen_query",
            "action": parsed_dosen.get("action", "list_dosen_current"),
            "prodi_id": parsed_dosen.get("prodi_id"),
            "prodi_name": parsed_dosen.get("prodi_name"),
            "context": {
                "kategori_pa": getattr(context, 'kategori_pa', None) or (context.get('kategori_pa') if isinstance(context, dict) else None),
                "prodi_id": getattr(context, 'prodi_id', None) or (context.get('prodi_id') if isinstance(context, dict) else None),
            } if context else {}
        }
        
        return json.dumps(dosen_plan)
    
    # Check if user is asking about pembimbing (lecturer assignment)
    if detect_pembimbing_command(prompt):
        print(f"[PLANNER] Detected PEMBIMBING command: {prompt}")
        
        # Get context
        context = dosen_context[0] if (isinstance(dosen_context, (list, tuple)) and len(dosen_context) > 0) else None
        
        # Parse pembimbing command
        parsed_pembimbing = parse_pembimbing_command(prompt, context)
        
        # Build pembimbing response plan
        pembimbing_plan = {
            "type": "pembimbing_command",
            "action": parsed_pembimbing.get("action", "view_all_pembimbing"),
            "kelompok_id": parsed_pembimbing.get("kelompok_id"),
            "kelompok_number": parsed_pembimbing.get("kelompok_number"),
            "context": {
                "kategori_pa": parsed_pembimbing.get("kpa_id") or (getattr(context, 'kategori_pa', None) or (context.get('kategori_pa') if isinstance(context, dict) else None)),
                "prodi_id": parsed_pembimbing.get("prodi_id") or (getattr(context, 'prodi_id', None) or (context.get('prodi_id') if isinstance(context, dict) else None)),
                "tahun_masuk": parsed_pembimbing.get("tm_id") or (getattr(context, 'angkatan', None) or (context.get('angkatan') if isinstance(context, dict) else None)),
            } if context else {
                "kategori_pa": parsed_pembimbing.get("kpa_id"),
                "prodi_id": parsed_pembimbing.get("prodi_id"),
                "tahun_masuk": parsed_pembimbing.get("tm_id"),
            }
        }
        
        return json.dumps(pembimbing_plan)

    # Check if user is just greeting
    if detect_greeting_keywords(prompt):
        # Get coordinator name and info from database
        coordinator_name = "Koordinator PA"
        kategori_pa = 1
        
        # Get user_id from context
        if isinstance(dosen_context, (list, tuple)) and len(dosen_context) > 0:
            ctx = dosen_context[0]
            request_user_id = None
            
            # Extract user_id from context
            if hasattr(ctx, 'user_id'):  # Pydantic model
                request_user_id = ctx.user_id
            elif isinstance(ctx, dict):
                request_user_id = ctx.get("user_id")
            
            # Get kategori_pa from context
            if hasattr(ctx, 'kategori_pa'):
                kategori_pa = ctx.kategori_pa
            elif isinstance(ctx, dict):
                kategori_pa = ctx.get("kategori_pa", 1)
            
            # Try to get dosen info from database
            if request_user_id:
                dosen_info = get_dosen_by_user_id(request_user_id)
                if dosen_info:
                    coordinator_name = dosen_info.get("nama", "Koordinator PA")
        
        greeting_response = {
            "type": "greeting",
            "message": f"Halo juga {coordinator_name} sebagai Koordinator PA {kategori_pa}, saya adalah agent Anda. Apakah ada yang ingin saya kerjakan hari ini?"
        }
        return json.dumps(greeting_response)
    
    # Check if user wants to view existing groups (general or specific by number)
    if detect_view_existing_groups(prompt):
        # First, try to extract specific group number
        group_number = extract_group_number(prompt)
        
        if group_number is not None:
            # User wants specific group (e.g., "tampilkan anggota kelompok 1")
            context = dosen_context[0] if (isinstance(dosen_context, (list, tuple)) and len(dosen_context) > 0) else None
            
            view_group_response = {
                "type": "view_group_by_number",
                "group_number": group_number,
                "context": {
                    "kategori_pa": getattr(context, 'kategori_pa', None) or (context.get('kategori_pa') if isinstance(context, dict) else None),
                    "prodi_id": getattr(context, 'prodi_id', None) or (context.get('prodi_id') if isinstance(context, dict) else None),
                    "angkatan": getattr(context, 'angkatan', None) or (context.get('angkatan') if isinstance(context, dict) else None),
                } if context else {}
            }
            return json.dumps(view_group_response)
        else:
            # User wants all groups (general view)
            request_user_id = None
            if isinstance(dosen_context, (list, tuple)) and len(dosen_context) > 0:
                ctx = dosen_context[0]
                if hasattr(ctx, 'user_id'):
                    request_user_id = ctx.user_id
                elif isinstance(ctx, dict):
                    request_user_id = ctx.get("user_id")
            
            view_response = {
                "type": "view_existing_groups",
                "user_id": request_user_id
            }
            return json.dumps(view_response)
    
    # ============ NEW: Detect Question vs Command ============
    # Jika user hanya bertanya, jangan parse sebagai instruksi grouping
    print(f"[PLANNER] Detecting question vs command for: {prompt}")
    query_type = detect_question_vs_command(prompt)
    print(f"[PLANNER] Query type: {query_type}")
    
    if query_type == "question":
        print(f"[PLANNER] This is a QUESTION, generating conversational response...")
        
        from agents.responder import respond_to_unrecognized_query
        from memory.advanced_operations import cache_get, cache_set
        
        # Extract context for direct answer patterns - handle both dict and Pydantic model
        context = None
        extracted_user_id = user_id  # Preserve the user_id parameter!
        
        if isinstance(dosen_context, (list, tuple)) and len(dosen_context) > 0:
            ctx = dosen_context[0]
            # Handle Pydantic model
            extracted_user_id = ctx.user_id if hasattr(ctx, 'user_id') else ctx.get('user_id', extracted_user_id)
            context = ctx.dict() if hasattr(ctx, 'dict') else ctx
        
        # Load group context from memory (from previous question)
        group_context = cache_get(f"last_group_context:{extracted_user_id}") if extracted_user_id else None
        
        # Generate natural language response dengan context untuk direct answers
        llm_response = respond_to_unrecognized_query(
            prompt, 
            context_data=context, 
            user_id=extracted_user_id,
            group_context=group_context,
            prompt_history=prompt
        )
        
        # Return response sebagai "natural_response" type
        response_data = {
            "type": "natural_response",
            "message": llm_response
        }
        return json.dumps(response_data)
    
    # ============ NEW: Use LLM Parser for Dynamic Requests ============
    print(f"[PLANNER] This is a COMMAND, using LLM parser for: {prompt}")
    
    parsed_request = parse_grouping_request(prompt)
    
    print(f"[PLANNER] Parsed request: {parsed_request}")
    
    # ============ CHECK: If parsing failed or action is None ============
    if not parsed_request.get("action") or parsed_request.get("action") in ["unknown", None, ""]:
        print(f"[PLANNER] WARNING: Parsing failed or action is None, generating LLM response...")
        
        # Import responder untuk generate natural response
        from agents.responder import respond_to_unrecognized_query
        from memory.advanced_operations import cache_get
        
        # Extract context for direct answer patterns - handle both dict and Pydantic model
        if isinstance(dosen_context, (list, tuple)) and len(dosen_context) > 0:
            ctx = dosen_context[0]
            # Handle Pydantic model
            user_id = ctx.user_id if hasattr(ctx, 'user_id') else ctx.get('user_id')
            context = ctx.dict() if hasattr(ctx, 'dict') else ctx
        else:
            user_id = None
            context = None
        
        # Load group context from memory (from previous question)
        group_context = cache_get(f"last_group_context:{user_id}") if user_id else None
        
        # Generate natural language response dengan context untuk direct answers
        llm_response = respond_to_unrecognized_query(
            prompt, 
            context_data=context, 
            user_id=user_id,
            group_context=group_context,
            prompt_history=prompt
        )
        
        # Return response sebagai "natural_response" type
        response_data = {
            "type": "natural_response",
            "message": llm_response
        }
        return json.dumps(response_data)
    
    # If parser detected action, build steps immediately
    if parsed_request.get("action") and parsed_request.get("action") != "unknown":
        context = dosen_context[0] if (isinstance(dosen_context, (list, tuple)) and len(dosen_context) > 0) else None
        
        steps_result = build_grouping_steps(parsed_request, context)
        
        if "error" not in steps_result:
            plan_response = {
                "type": "dynamic_grouping",
                "parsed": parsed_request,
                "steps": steps_result.get("steps", []),
                "metadata": steps_result.get("metadata", {})
            }
            return json.dumps(plan_response)
    
    # Jika ada existing_groups, prepare context-nya
    prior_memory_text = ""
    existing_groups_context = ""
    if user_id is not None:
        memory_list = get_memory_by_user(user_id)
        if memory_list:
            prior_memory_text = "\n".join([f"[history] prompt={m.get('prompt')} | feedback={m.get('feedback')}" for m in memory_list[-5:]])
    
    if existing_groups:
        groups_summary = []
        for group in existing_groups:
            members_str = ", ".join([m.get("nama", "?") for m in group.get("members", [])])
            groups_summary.append(f"Kelompok {group.get('kelompok')}: {members_str}")
        existing_groups_context = "EXISTING GROUPS:\n" + "\n".join(groups_summary)

    system_prompt = f"""
Kamu adalah AI Agent Koordinator PA.

TASK UTAMA:
1. Jika ada instruksi grouping BARU, WAJIB ambil mahasiswa dulu
2. Jika ada instruksi MODIFY existing groups (acak, ubah constraint, dll), gunakan modify_existing_groups
3. Jika ada instruksi grouping berdasarkan NILAI/SCORE, gunakan get_student_scores_by_category terlebih dahulu
4. Parse constraint dari prompt user (must_pairs/avoid_pairs)
5. Lakukan grouping dengan constraint tersebut

---

TOOLS:

1. get_mahasiswa
   - untuk mengambil data mahasiswa
   - WAJIB gunakan dosen_context
   
2. get_student_scores_by_category
   - untuk mengambil nilai matakuliah mahasiswa berdasarkan kategori_pa
   - kategori_pa dari dosen_context menentukan semester yang diambil
   - kategori_pa = 1: semester 1
   - kategori_pa = 2: semester 1, 2, 3
   - kategori_pa = 3: semester 1, 2, 3, 4, 5
   - GUNAKAN INI jika user sebut "nilai", "skor", "semester", atau grouping berdasarkan "prestasi"

3. grouping
   - untuk membagi kelompok mahasiswa dengan constraint biasa (random-based)
   - param group_size: UKURAN PER KELOMPOK (jika user bilang "5 orang per kelompok")
   - param num_groups: JUMLAH KELOMPOK TARGET (jika user bilang "5 kelompok")
   - GUNAKAN SALAH SATU: num_groups OR group_size, jangan keduanya

4. grouping_by_score
   - untuk membagi kelompok mahasiswa berdasarkan NILAI/SCORE
   - GUNAKAN INI jika sudah call get_student_scores_by_category
   - akan balance group sehingga nilai rata-rata per kelompok tidak jauh dari rata-rata kelas

5. grouping_by_career
   - untuk membagi kelompok mahasiswa berdasarkan KARIR/KATEGORI MATAKULIAH (Backend, Frontend, UI/UX, Data AI)
   - GUNAKAN INI jika sudah call get_student_scores_by_category
   - akan menggunakan LLM untuk kategorisasi matakuliah dan score mahasiswa per karir
   - akan balance group sehingga setiap kelompok memiliki perwakilan dari setiap kategori karir
   - terbaik untuk membuat kelompok dengan skill distribution yang merata

6. modify_existing_groups
   - untuk MODIFY kelompok yang sudah ada
   - GUNAKAN INI HANYA jika ada EXISTING_GROUPS context di bawah!
   - Jika EXISTING_GROUPS kosong, gunakan regular grouping dengan shuffle/constraints
   - params: {{"shuffle": boolean, "must_pairs": [], "avoid_pairs": []}}
   - JANGAN ambil mahasiswa atau scores lagi, langsung modify dari existing groups

---

PRIORITY RULES:
1. Jika ada EXISTING_GROUPS context (bukan kosong) → Gunakan modify_existing_groups untuk modify
2. Jika EXISTING_GROUPS kosong → Gunakan regular grouping/grouping_by_score/grouping_by_career DENGAN shuffle=true SECARA DEFAULT
3. Jangan membuat modify_existing_groups action jika tidak ada existing groups!
4. Jika user ingin grouping berdasarkan KARIR (detect keywords: karir, kategori, balance, seimbang, backend, frontend, ui, ux, data, ai)
   → GUNAKAN grouping_by_career SETELAH get_student_scores_by_category

---

RANDOM GROUPING (SHUFFLE) DEFAULT RULES:
- Ketika user meminta "buat kelompok", "bagi kelompok" → WAJIB gunakan shuffle: true SECARA DEFAULT
- Ketika user meminta random/acak → shuffle: true
- Ketika user secara EKSPLISIT minta "tidak acak", "urut", "teratur" → shuffle: false
- Untuk modify_existing_groups: Gunakan shuffle: true jika ada keyword "acak" atau "buat ulang"

UNTUK SETIAP ACTION GROUPING/GROUPING_BY_SCORE:
- DEFAULT: shuffle=true (KECUALI user eksplisit bilang "tidak acak")
- USER TIDAK PERLU BILANG "ACAK", SUDAH OTOMATIS ACAK!
- INI ARTINYA: Ketika user: "Bagi 50 mahasiswa jadi 5 per kelompok" → OTOMATIS gunakan shuffle=true

---

DETECT MODIFY KEYWORDS:
Jika user sebut: "acak", "ubah", "jangan", "harus", "kembali", "ulangi", "ganti", "tukar"
  → Jika ada EXISTING_GROUPS: Gunakan modify_existing_groups
  → Jika TIDAK ada EXISTING_GROUPS: Gunakan regular grouping/grouping_by_score dengan constraints/shuffle

---

PARSING CONSTRAINT (SANGAT PENTING):

EKSTRAK SEMUA NAMA DARI TEXT USER:
  - Cari semua kata yang terlihat seperti nama (Capitalized words atau setelah keywords)
  - Keyword harus dikombinasi dengan nama yang mengikutinya

CONTOH PARSING:
  User: "mai pane harus satu kelompok dengan lastri rohani"
  → Extract: "mai pane", "lastri rohani"
  → must_pairs: [["mai pane", "lastri rohani"]]
  
  User: "gahasa tidak boleh satu kelompok dengan geby"
  → Extract: "gahasa", "geby"
  → avoid_pairs: [["gahasa", "geby"]]

JIKA TIDAK ADA NAMA SPESIFIK:
  must_pairs: []
  avoid_pairs: []

SHUFFLE KEYWORD:
  Jika user sebut "acak", "random", "shuffle", "kocok" → shuffle: true
  Jika user sebut "buat kelompok", "bagi kelompok" tanpa keyword khusus → shuffle: true (DEFAULT)
  Sebaliknya (user secara eksplisit minta "terurut", "tidak acak", dll) → shuffle: false

SCORE-BASED GROUPING KEYWORDS:
  Jika user sebut: "nilai", "skor", "prestasi", "semester", "IPK", "nilai matkul"
  → Gunakan get_student_scores_by_category TERLEBIH DAHULU
  → Kemudian gunakan grouping_by_score

---

INSTRUKSI GROUPING:

- Jika user bilang "N kelompok" (contoh "5 kelompok") → WAJIB gunakan parameter num_groups: N
- Jika user bilang "5-6 orang" → gunakan group_size: 6 atau 5 (yang lebih sesuai)
- Ubah semua "/ sampai" menjadi group_size max
- Pastikan kelompok MERATA (tidak ada yang terlalu kecil)
- PENTING: Untuk setiap grouping/grouping_by_score, set shuffle: true SECARA DEFAULT (kecuali user eksplisit tidak mau)
- Jika ada keyword "acak", "buat kelompok", "bagi kelompok" → shuffle: true
- Hanya jika user eksplisit minta "tidak acak" atau "urut" → shuffle: false

PERBEDAAN num_groups vs group_size:
- num_groups: TARGET JUMLAH KELOMPOK (contoh: user bilang "5 kelompok")
  → Sistem hitung optimal size per kelompok untuk mencapai target
  → Example: 69 mahasiswa, num_groups=5 → setiap kelompok ~14 orang
- group_size: UKURAN PER KELOMPOK (contoh: user bilang "5 per kelompok")
  → Sistem buat sebanyak mungkin kelompok dengan ukuran tsb
  → Example: 69 mahasiswa, group_size=5 → 14 kelompok dengan ukuran 5-6 orang

---

OUTPUT JSON RULES:

1. HARUS valid JSON, NO MARKDOWN (jangan pakai ``` json)
2. Struktur step:
   - action: string (get_mahasiswa, get_student_scores_by_category, grouping, grouping_by_score)
   - params: object dengan field sesuai action

3. Group_size harus dari prompt (default 6)
4. Must_pairs dan avoid_pairs harus ARRAY OF ARRAYS
5. SHUFFLE DEFAULT: shuffle SELALU true kecuali user EKSPLISIT bilang "tidak acak"
   - INGAT: Default untuk setiap grouping adalah shuffle=true
   - Hanya gunakan shuffle=false jika user secara JELAS minta "tidak acak" atau "teratur"

---

CONTOH OUTPUT GROUPING DENGAN JUMLAH KELOMPOK SPESIFIK (user bilang "5 kelompok"):

{{
  "steps": [
    {{
      "action": "get_mahasiswa",
      "params": {{
        "use_context": true,
        "fields": ["nama", "nim"]
      }}
    }},
    {{
      "action": "grouping",
      "params": {{
        "num_groups": 5,
        "must_pairs": [],
        "avoid_pairs": [],
        "shuffle": true
      }}
    }}
  ]
}}

---

CONTOH OUTPUT SCORE-BASED GROUPING (dengan shuffle default):

{{
  "steps": [
    {{
      "action": "get_mahasiswa",
      "params": {{
        "use_context": true,
        "fields": ["nama", "nim", "user_id"]
      }}
    }},
    {{
      "action": "get_student_scores_by_category",
      "params": {{
        "use_context": true,
        "kategori_pa_from_context": true
      }}
    }},
    {{
      "action": "grouping_by_score",
      "params": {{
        "group_size": 6,
        "allow_deviation": 0.5,
        "must_pairs": [["Nama A", "Nama B"]],
        "avoid_pairs": [["Nama C", "Nama D"]],
        "shuffle": true
      }}
    }}
  ]
}}

---

CONTOH OUTPUT REGULAR GROUPING (dengan shuffle default=true):

{{
  "steps": [
    {{
      "action": "get_mahasiswa",
      "params": {{
        "use_context": true,
        "fields": ["nama", "nim"]
      }}
    }},
    {{
      "action": "grouping",
      "params": {{
        "group_size": 6,
        "must_pairs": [["Nama A", "Nama B"]],
        "avoid_pairs": [["Nama C", "Nama D"]],
        "shuffle": true
      }}
    }}
  ]
}}

---

CONTOH OUTPUT MODIFY EXISTING GROUPS (dengan shuffle=true untuk randomize ulang):

{{
  "steps": [
    {{
      "action": "modify_existing_groups",
      "params": {{
        "shuffle": true,
        "must_pairs": [["Nama A", "Nama B"]],
        "avoid_pairs": [["Nama C", "Nama D"]]
      }}
    }}
  ]
}}

---

Context dosen:
{dosen_context}

{existing_groups_context}

Memory prior:
{prior_memory_text}
"""

    try:
        response = client.chat.completions.create(
            model="gpt-4.1-mini",
            messages=[
                {"role": "system", "content": system_prompt},
                {"role": "user", "content": prompt}
            ],
            temperature=0
        )

        result = response.choices[0].message.content

        return clean_json(result)

    except Exception as e:
        return f'{{"error": "{str(e)}"}}'